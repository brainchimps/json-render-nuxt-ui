{
  "name": "json-render-nuxt-ui",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "description": "Nuxt UI component library for json-render. JSON becomes beautiful Tailwind-styled Vue components.",
  "keywords": [
    "json",
    "ui",
    "vue",
    "nuxt-ui",
    "tailwind",
    "reka-ui",
    "ai",
    "generative-ui",
    "llm",
    "renderer",
    "streaming",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brainchimps/json-render-nuxt-ui.git"
  },
  "homepage": "https://github.com/brainchimps/json-render-nuxt-ui#readme",
  "bugs": {
    "url": "https://github.com/brainchimps/json-render-nuxt-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.mjs",
      "require": "./dist/catalog.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@json-render/vue": "^0.16.0"
  },
  "devDependencies": {
    "tsup": "8.5.0",
    "typescript": "5.8.2",
    "vitest": "3.2.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nuxt/ui": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0",
    "zod": "^4.0.0"
  }
}
